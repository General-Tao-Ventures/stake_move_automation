# Wallet password for sn35 wallet
WALLET_PASSWORD=your_wallet_password_here

# Telegram bot token (optional - for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID (optional - for notifications)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Sheets integration (optional - for accounting/logging)
GOOGLE_SERVICE_ACCOUNT_JSON=/opt/stake-move-automation/google-sheets-sa.json
GOOGLE_SHEET_ID=your_google_sheet_id_here
